{
  "name": "boucheck-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#validators/*": "./app/validators/*.js",
    "#config/*": "./config/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js"
  },
  "scripts": {
    "dev": "node ace serve --watch",
    "build": "node ace build",
    "start": "node bin/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "worker": "npx tsx bin/worker.ts",
    "test": "node ace test"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.6.0",
    "@adonisjs/core": "^6.14.1",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/limiter": "^2.4.0",
    "@adonisjs/lucid": "^21.3.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1084.0",
    "@aws-sdk/client-ses": "^3.1085.0",
    "@aws-sdk/client-sqs": "^3.1083.0",
    "@vinejs/vine": "^4.4.0",
    "luxon": "^3.5.0",
    "pg": "^8.13.1",
    "playwright-chromium": "^1.52.0",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/tsconfig": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.7.42",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0"
  }
}
