NODE_ENV=development
PORT=3333
HOST=0.0.0.0
APP_KEY=
LOG_LEVEL=info

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=boucheck

# CDN
CDN_BASE_URL=https://cdn.boucheck.beonup.com.br

# AWS / S3
S3_LOGOS_BUCKET=boucheck-logos
S3_REPORTS_BUCKET=boucheck-reports

# AWS SQS (Reporting Queue)
SQS_REPORTING_QUEUE_URL=
AWS_REGION=us-east-1

# AWS SES (Email delivery)
SES_FROM_EMAIL=noreply@boucheck.beonup.com.br

# AWS SQS (Foundation mail queue — password resets, temp passwords)
SQS_MAIL_QUEUE_URL=

# AWS S3 (Reports bucket)
S3_REPORTS_BUCKET=boucheck-reports

# AWS Bedrock (AI question generation)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=sa-east-1
BEDROCK_TIMEOUT_MS=60000

# WhatsApp Cloud API (Report delivery)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_TEMPLATE_NAME=report_delivery
WHATSAPP_TEMPLATE_LANGUAGE=pt_BR